# Production environment — TerasDesa Backend
# Copy this file to .env on the VPS and fill in the values

PORT=3008

# Prisma DATABASE_URL — constructed from DB credentials provided by DevOps
# IMPORTANT: if the password contains special characters (e.g. / = @ #),
# they must be URL-encoded. Example: "/" becomes "%2F"
DATABASE_URL="mysql://database:<passIFany>@mariadb:3306/db_name"

JWT_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"

# URL of the deployed frontend (for CORS).
# Must NOT end with a trailing slash. Use * only for testing.
# Multiple origins can be separated by commas.
# Example: "https://teras-desa.vercel.app,https://staging.example.com"
FRONTEND_URL=""

# Google OAuth (optional — leave empty if not using)
GOOGLE_CLIENT_ID=""

# Supabase Storage Configuration
# Find these in Supabase Dashboard > Settings > API
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
